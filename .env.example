# Loaded via src/config/api.config.ts → ConfigService keys like api.port, mail.host, jwt.accessSecret
APP_NAME=Ganges Grill
SUPPORT_EMAIL=support@example.com
NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ganges_grill?schema=public

# JWT (nested under `jwt.*` in ConfigService)
JWT_ACCESS_SECRET=replace-with-strong-random-secret
JWT_ACCESS_EXPIRES_SEC=900
REFRESH_TOKEN_EXPIRES_DAYS=7
OTP_PEPPER=
# Legacy alias if JWT_ACCESS_SECRET is unset:
# access_token=

# Redis (`redis.*`) — BullMQ mail queue
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=

# SMTP (`mail.*`) — prefer SMTP_PASS; GMAIL_PASSWORD still accepted as fallback in api.config
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
GMAIL_PASSWORD=
SMTP_FROM=


