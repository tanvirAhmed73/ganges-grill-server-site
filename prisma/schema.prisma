generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String
  role      UserRole   @default(user)

  /// Argon2 hash; null for legacy rows until the user sets a password (e.g. via a future reset flow).
  passwordHash String? @map("password_hash")

  emailVerifiedAt DateTime? @map("email_verified_at")

  /// Hashed email verification OTP (argon2); cleared after verify or password change.
  verificationCodeHash String? @map("verification_code_hash")
  verificationExpiresAt DateTime? @map("verification_expires_at")

  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  cartItems     CartItem[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model MenuItem {
  id        String     @id @default(uuid())
  name      String
  recipe    String
  image     String
  category  String
  price     Decimal    @db.Decimal(10, 2)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  cartItems CartItem[]

  @@index([category])
  @@map("menu_items")
}

model CartItem {
  id         String    @id @default(uuid())
  foodId     String    @map("food_id")
  email      String
  name       String
  image      String
  price      Decimal   @db.Decimal(10, 2)
  userId     String    @map("user_id")
  menuItemId String?   @map("menu_item_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  menuItem   MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([userId])
  @@map("cart_items")
}
